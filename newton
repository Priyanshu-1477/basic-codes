#include <iostream>
#include <iomanip>
using namespace std;

#define MAX 10

// Factorial function
int fact(int n) {
    int f = 1;
    for(int i = 1; i <= n; i++) f *= i;
    return f;
}

// Function to print difference table
void printTable(float x[], float y[MAX][MAX], int n) {
    cout << "\nDifference Table:\n";
    cout << setw(10) << "x" << setw(10) << "y";

    for(int i = 1; i < n; i++) {
        cout << setw(10) << "Δ^" + to_string(i) + "y";
    }
    cout << endl;

    for(int i = 0; i < n; i++) {
        cout << setw(10) << x[i];
        for(int j = 0; j < n - i; j++) {
            cout << setw(10) << y[i][j];
        }
        cout << endl;
    }
}

int main() {
    int n = 4;
    float x[] = {1, 2, 3, 4};
    float y[MAX][MAX];

    // Given values
    y[0][0] = 1;
    y[1][0] = 8;
    y[2][0] = 27;
    y[3][0] = 64;

    // Build difference table
    for(int j = 1; j < n; j++) {
        for(int i = 0; i < n - j; i++) {
            y[i][j] = y[i+1][j-1] - y[i][j-1];
        }
    }

    // Print table
    printTable(x, y, n);

    // -----------------------------
    // Forward Interpolation (x = 1.5)
    // -----------------------------
    float value = 1.5;
    float h = x[1] - x[0];
    float p = (value - x[0]) / h;

    float forward = y[0][0];

    for(int i = 1; i < n; i++) {
        float term = 1;
        for(int j = 0; j < i; j++) {
            term *= (p - j);
        }
        forward += (term * y[0][i]) / fact(i);
    }

    cout << "\nForward Interpolation at x = 1.5: " << forward << endl;

    // -----------------------------
    // Backward Interpolation (x = 5)
    // -----------------------------
    value = 5;
    p = (value - x[n-1]) / h;

    float backward = y[n-1][0];

    for(int i = 1; i < n; i++) {
        float term = 1;
        for(int j = 0; j < i; j++) {
            term *= (p + j);
        }
        backward += (term * y[n-i-1][i]) / fact(i);
    }

    cout << "Backward Interpolation at x = 5: " << backward << endl;

    return 0;
}